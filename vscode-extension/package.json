{
  "name": "medullo-vscode",
  "displayName": "Medullo — Code Context",
  "description": "A quiet companion that captures where you are in your code, so Medullo can reconstruct your train of thought after an interruption.",
  "version": "0.1.1",
  "publisher": "medullo",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Isaaciyo/medullo-cognitive-companion.git"
  },
  "homepage": "https://medullo-cognitive-companion.vercel.app",
  "bugs": {
    "url": "https://github.com/Isaaciyo/medullo-cognitive-companion/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Education"
  ],
  "keywords": [
    "cognitive continuity",
    "context capture",
    "productivity",
    "memory",
    "ai",
    "focus",
    "interruption"
  ],
  "galleryBanner": {
    "color": "#F3EFFD",
    "theme": "light"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "configuration": {
      "title": "Medullo",
      "properties": {
        "medullo.backendUrl": {
          "type": "string",
          "default": "https://medullo-cognitive-companion-production.up.railway.app",
          "description": "URL of your Medullo backend. Defaults to the hosted Railway backend. Use http://localhost:8000 for self-hosted."
        },
        "medullo.accessToken": {
          "type": "string",
          "default": "",
          "description": "Optional Medullo bearer token. Paste the token from the Chrome extension to send browser and VS Code context to the same account."
        }
      }
    }
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0"
  },
  "scripts": {
    "test": "echo \"No tests yet\"",
    "vsce:package": "vsce package",
    "vsce:publish": "vsce publish"
  }
}

# Medullo — top-level env for `docker compose up`.
# Copy to .env and fill in values.

# Required: Gemini API key for cognitive snapshot generation
GEMINI_API_KEY=

# Optional: pin a different Gemini model
GEMINI_MODEL=gemini-2.5-pro

# Optional: port overrides (defaults shown)
BACKEND_PORT=8000
FRONTEND_PORT=3000

# Optional: point the frontend at a different backend (default = localhost:8000).
# Change this if you're running the backend on a different host.
NEXT_PUBLIC_API_URL=http://localhost:8000
